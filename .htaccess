# ============================================================
# Clean URL Routing - Remove .html Extension
# ============================================================
# This .htaccess file handles:
# 1. 301 redirects from .html URLs to clean URLs
# 2. Internally serves .html files for clean URLs
# 3. Consistent trailing slash handling (no trailing slash)
# 4. Full backward compatibility
# ============================================================

RewriteEngine On

# --- Force HTTPS (uncomment if SSL is enabled) ---
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Remove trailing slash (except for directories) ---
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [L,R=301]

# --- Redirect .html extension to clean URL (301 Permanent) ---
# This handles: /about-us.html -> /about-us
# Also handles: /index.html -> /
RewriteCond %{THE_REQUEST} \s/index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [L,R=301]

RewriteCond %{THE_REQUEST} \s/(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [L,R=301,NE]

# --- Serve .html files for clean URLs (internal rewrite) ---
# If the request doesn't match an existing file or directory,
# try appending .html and serve that file
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# --- Handle the root/index page ---
DirectoryIndex index.html

# --- Error Pages (optional) ---
ErrorDocument 404 /index.html

# --- Cache Control for static assets ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>
